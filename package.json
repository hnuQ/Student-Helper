{
  "name": "student-helper",
  "version": "2.1.2",
  "description": "Student Helper desktop app",
  "author": "Jensenyjc <jensenyjc@example.com>",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "prisma generate && electron-builder install-app-deps",
    "prisma:generate": "prisma generate",
    "build:win": "npm run build && npm run prisma:generate && electron-builder --win nsis",
    "build:mac": "npm run build && npm run prisma:generate && electron-builder --mac",
    "build:mac-standalone": "npm run build && npm run prisma:generate && electron-builder --config electron-builder-mac.yml",
    "build:linux": "npm run build && npm run prisma:generate && electron-builder --linux",
    "build:linux-standalone": "npm run build && npm run prisma:generate && electron-builder --config electron-builder-linux.yml"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-log": "^5.2.0",
    "lucide-react": "^0.460.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shelljs": "^0.8.5",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^10.0.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
